# Copy this file to `.env` and fill in the values.
# `.env` is gitignored and must never be committed.

# --- Discord ---
# Bot token from https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_TOKEN=

# Optional: a server (guild) ID for INSTANT slash-command sync while developing.
# Leave blank to sync commands globally (can take up to ~1 hour to appear in Discord).
DEV_GUILD_ID=

# --- Lavalink ---
# When running the bot directly on your machine, Lavalink is on localhost.
# (docker-compose overrides this to http://lavalink:2333 for the containerized bot.)
LAVALINK_URI=http://localhost:2333
# Must match the password in lavalink/application.yml
LAVALINK_PASSWORD=youshallnotpass

# --- Misc ---
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
